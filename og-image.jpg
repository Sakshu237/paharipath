</span></span><span><span></span><span class="token token" style="color: rgb(129, 0, 194);">create</span><span> policy </span><span class="token token" style="color: rgb(0, 128, 0);">"Authenticated can read"</span><span> </span><span class="token token" style="color: rgb(129, 0, 194);">on</span><span> partner_applications </span><span class="token token" style="color: rgb(129, 0, 194);">for</span><span> </span><span class="token token" style="color: rgb(129, 0, 194);">select</span><span> </span><span class="token token" style="color: rgb(129, 0, 194);">using</span><span> </span><span class="token token" style="color: rgb(43, 48, 59);">(</span><span>auth</span><span class="token token" style="color: rgb(43, 48, 59);">.</span><span>role</span><span class="token token" style="color: rgb(43, 48, 59);">(</span><span class="token token" style="color: rgb(43, 48, 59);">)</span><span> </span><span class="token token" style="color: rgb(20, 24, 31);">=</span><span> </span><span class="token token" style="color: rgb(0, 128, 0);">'authenticated'</span><span class="token token" style="color: rgb(43, 48, 59);">)</span><span class="token token" style="color: rgb(43, 48, 59);">;</span></span></code></pre></div></div>
<hr class="border-border-200 border-t-0.5 my-3 mx-1.5">
<h3 class="text-text-100 mt-3 -mb-1 text-[1.125rem] font-bold">Step 7 — Update your WhatsApp number in the code</h3>
<p class="font-claude-response-body break-words whitespace-normal">In <code class="bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]">PahariPath_v4_full.html</code>, search for <code class="bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]">91XXXXXXXXXX</code> and replace it with your actual WhatsApp number (with country code, no +).</p>
<p class="font-claude-response-body break-words whitespace-normal">Then re-upload to Netlify.</p>
<hr class="border-border-200 border-t-0.5 my-3 mx-1.5">
<h3 class="text-text-100 mt-3 -mb-1 text-[1.125rem] font-bold">Step 8 — Sign up on Razorpay</h3>
<ol class="[li_&amp;]:mb-0 [li_&amp;]:mt-1 [li_&amp;]:gap-1 [&amp;:not(:last-child)_ul]:pb-1 [&amp;:not(:last-child)_ol]:pb-1 list-decimal flex flex-col gap-1 pl-8 mb-3">
<li class="font-claude-response-body whitespace-normal break-words pl-2">Go to <strong>razorpay.com</strong> → Create account</li>
<li class="font-claude-response-body whitespace-normal break-words pl-2">Complete KYC (PAN + bank account)</li>
<li class="font-claude-response-body whitespace-normal break-words pl-2">Takes 1-3 days for approval</li>
<li class="font-claude-response-body whitespace-normal break-words pl-2">Once approved, come back and we'll wire the payment into the booking flow in one session</li>
</ol>
<hr class="border-border-200 border-t-0.5 my-3 mx-1.5">
<h3 class="text-text-100 mt-3 -mb-1 text-[1.125rem] font-bold">Step 9 — Start reaching out to homestay partners</h3>
<p class="font-claude-response-body break-words whitespace-normal">While all the above is running in background, DM 5 homestay owners on Instagram. Search:</p>
<ul class="[li_&amp;]:mb-0 [li_&amp;]:mt-1 [li_&amp;]:gap-1 [&amp;:not(:last-child)_ul]:pb-1 [&amp;:not(:last-child)_ol]:pb-1 list-disc flex flex-col gap-1 pl-8 mb-3">
<li class="font-claude-response-body whitespace-normal break-words pl-2"><code class="bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]">#tirthanhomestay</code></li>
<li class="font-claude-response-body whitespace-normal break-words pl-2"><code class="bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]">#spitistay</code></li>
<li class="font-claude-response-body whitespace-normal break-words pl-2"><code class="bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]">#jibhihomestay</code></li>
<li class="font-claude-response-body whitespace-normal break-words pl-2"><code class="bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]">#birstay</code></li>
</ul>
<p class="font-claude-response-body break-words whitespace-normal">Simple message: <em>"I'm building a responsible travel platform for HP called PahariPath. Free listing, bookings direct to your WhatsApp. Interested?"</em></p>
<hr class="border-border-200 border-t-0.5 my-3 mx-1.5">
<h3 class="text-text-100 mt-3 -mb-1 text-[1.125rem] font-bold">Where you are after all 9 steps</h3>
<ul class="[li_&amp;]:mb-0 [li_&amp;]:mt-1 [li_&amp;]:gap-1 [&amp;:not(:last-child)_ul]:pb-1 [&amp;:not(:last-child)_ol]:pb-1 list-disc flex flex-col gap-1 pl-8 mb-3">
<li class="font-claude-response-body whitespace-normal break-words pl-2">✅ Live website at <code class="bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]">paharipath.in</code></li>
<li class="font-claude-response-body whitespace-normal break-words pl-2">✅ HTTPS, PWA installable on phone</li>
<li class="font-claude-response-body whitespace-normal break-words pl-2">✅ Analytics tracking visitors</li>
<li class="font-claude-response-body whitespace-normal break-words pl-2">✅ Partners can apply to list</li>
<li class="font-claude-response-body whitespace-normal break-words pl-2">✅ Razorpay approved and ready to wire in</li>
<li class="font-claude-response-body whitespace-normal break-words pl-2">✅ First homestay conversations started</li>
</ul>
